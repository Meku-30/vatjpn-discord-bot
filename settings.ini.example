[VATSIM_CONFIG]
vatsim_stat_json_url=https://data.vatsim.net/v3/vatsim-data.json
vatsim_stat_retrieve_period=15
vatsim_controller_callsign_filter_regex=(^RJ|^ROAH|^ROB|^ROD|^ROI|^ROK|^ROM|^ROR|^ROT|^ROY|^VATJ|^OKA_|^FUK_|^KOJ_|^TYO_|^HDK_|^SRK_)[A-Za-z_][A-Za-z_]([0-9]|[A-Za-z_]|$)([0-9]|[A-Za-z_]|$)+$(?<!_OBS)

[DISCORD_CONFIG]
discord_channel_id=YOUR_CHANNEL_ID

[DATAFILE_CONFIG]
data_filename=data.json
nickname_filename=nicknames.json
stats_db_filename=stats.db

# NOTAM feature requires FAA API credentials in .env:
#   FAA_CLIENT_ID=your_id
#   FAA_CLIENT_SECRET=your_secret
# Register at https://api.faa.gov/s/
